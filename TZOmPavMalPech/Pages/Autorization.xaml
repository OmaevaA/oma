<Page x:Class="TZOmPavMalPech.Pages.Autorization"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TZOmPavMalPech.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
        Title="Авторизация">

    <Grid>
        <!-- Добавление теста и текстовых полей -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="Логин:" ></TextBlock>
                <TextBox Name="TBoxLogin" ></TextBox>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="Пароль:" ></TextBlock>
                <PasswordBox Name="PboxPassword"  Margin="0,5,0,0" Width="180" Height="40"></PasswordBox>
            </StackPanel>
            <!-- Добавление кнопки -->
            <Button Name="BtnLogin" Content="Войти"  HorizontalAlignment="Center"  Click="BtnLogin_Click"></Button>
            <Button Name="BtnGuest" Content="Войти как гость!"  HorizontalAlignment="Center"  Click="BtnGuest_Click" ></Button>
        </StackPanel>
    </Grid>
</Page>
