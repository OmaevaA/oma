<Page x:Class="TZOmPavMalPech.Pages.Catalog"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TZOmPavMalPech.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
        Title="Книжный каталог" Loaded="Page_Loaded_2" >

    <Grid>
        <!-- Добавление разметки -->
        <Grid.RowDefinitions>
            <RowDefinition Height="50"></RowDefinition>
            <RowDefinition Height="20"></RowDefinition>
            <RowDefinition Height="50"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="50"></RowDefinition>
        </Grid.RowDefinitions>

        <!-- Вывод роли  -->
        <TextBlock Grid.Column="2" HorizontalAlignment="Right"  x:Name="UsernameLabel">
            Роль: <Run Text="{Binding FIO}"/></TextBlock>

        <!-- элементы для  сортировки, поиска в верстке:  -->
        <StackPanel Orientation="Horizontal"  HorizontalAlignment="Center">
            <ComboBox Margin="5" Width="220" Visibility="{Binding Control}" Name="ComboSortBy" 
              SelectionChanged="ComboSortBy_SelectionChanged" Background="#F5E6D3">
                <ComboBoxItem Content="Все"></ComboBoxItem>
                <ComboBoxItem Content="Роман-эпопея"></ComboBoxItem>
                <ComboBoxItem Content="Роман"></ComboBoxItem>
                <ComboBoxItem Content="Сатира"></ComboBoxItem>
                <ComboBoxItem Content="Проза / Притча"></ComboBoxItem>
                <ComboBoxItem Content="Трагедия"></ComboBoxItem>
            </ComboBox>

            <!-- по издательству-->
            <ComboBox Margin="5" Visibility="{Binding Control}" Width="220" Name="ComboSortSuplier" 
              SelectionChanged="ComboSortSuplier_SelectionChanged" >
               
                <ComboBoxItem Content="Все"></ComboBoxItem>
                <ComboBoxItem Content="Староста"></ComboBoxItem>
                <ComboBoxItem Content="Око"></ComboBoxItem>
                <ComboBoxItem Content="Стветлая знать"></ComboBoxItem>
            </ComboBox>

            <!-- поиск-->
            <TextBox Name="TBoxSearch"  Visibility="{Binding Control}" Margin="5" Width="220" 
             SelectionChanged="TBoxSearch_SelectionChanged"></TextBox>
        </StackPanel>

        <!-- Добавление списка -->
        <ListView Grid.Row="3" Name="LviewProduct">

            <ListView.ItemTemplate>
                <DataTemplate>

                    <!-- Изменение фона, если скидка больше 15% и товара нет в наличии-->
                    <Border BorderBrush="#2E8B57" CornerRadius="15" Padding="5" 
                    Background="{Binding BackColor}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"></ColumnDefinition>
                                <ColumnDefinition Width="1700"></ColumnDefinition>
                                <ColumnDefinition Width="*"></ColumnDefinition>
                            </Grid.ColumnDefinitions>


                            <StackPanel Grid.Column="1">
                                <DockPanel LastChildFill="True">
                                    <StackPanel Orientation="Vertical">
                                    <!-- Вывод автора  -->
                                    <TextBlock FontFamily="Times New Roman" FontWeight="Bold" 
                                       DockPanel.Dock="Left" Width="230"
                                        FontSize="18"  Text="{Binding Name}"></TextBlock>
                                    <!-- Добавление изображения-->
                                        <Image Source="{Binding Image, FallbackValue=/res/picture.jpg}" Stretch="Uniform" HorizontalAlignment="Left"  Width="200" Height="200"></Image>
                                        </StackPanel>
                                    <!-- Добавьте в StackPanel с кнопками или рядом с названием -->
                                    
                                    <!-- Вывод разделителя  -->
                                    <TextBlock  DockPanel.Dock="Left"  Width="30" Text=" | "></TextBlock>

                                    <StackPanel Orientation="Vertical">
                                        <!-- Вывод Названия  -->
                                        <TextBlock  FontWeight="Bold"  DockPanel.Dock="Left" HorizontalAlignment="Left" 
                                            Width="500" Text="{Binding Avtor}"></TextBlock>

                                        <!-- Вывод Жанра  -->
                                        <TextBlock 
                                           DockPanel.Dock="Left" HorizontalAlignment="Left"  Width="250">
   <Run Text="Жанр: "/> <Run Text="{Binding Genre.Name}"/></TextBlock>
                                        <!-- Вывод описание  -->
                                        <TextBlock   DockPanel.Dock="Left" 
                                           HorizontalAlignment="Left"  Width="800">
    <Run Text="Описание: "/> <Run Text="{Binding Discription}"/></TextBlock>
                                        <!-- Вывод издательства  -->
                                        <TextBlock    DockPanel.Dock="Left" HorizontalAlignment="Left"  Width="600">                                    
   <Run Text="Издательство: "/> <Run Text="{Binding Publisher.Name}"/></TextBlock>

                                        <TextBlock  DockPanel.Dock="Left" HorizontalAlignment="Left"  > 
                             <Run Text="Год издания: "/>       <Run    Text="{Binding DateBook,StringFormat={}{0:dd.MM.yyyy}}"/>
                                        </TextBlock>

                                        <StackPanel Orientation="Horizontal">
                                            <!-- Чекбокс для отметки прочитанного -->
                                                <CheckBox Name="ChkRead" 
              Content="Прочитано"
              IsChecked="{Binding IsReadByUser, Mode=TwoWay}"
              Visibility="{Binding ReadCheckBoxVisibility}"
              Click="ChkRead_Click"
              />
                                                <Button Content="Редактировать"  Name="Edid" Visibility="{Binding Control}"
                                        Click="Edid_Click"  ></Button>
                                            <Button Content="Удалить" Name="Del" Visibility="{Binding Control}" Click="Del_Click"></Button>

                                        </StackPanel>
                                    </StackPanel>

                                </DockPanel>

                            </StackPanel>

                        </Grid>
                    </Border>

                </DataTemplate>
            </ListView.ItemTemplate>

        </ListView>

        <!-- Добавление кнопки добавить -->
        <Button Grid.Row="4"   HorizontalAlignment="Right" Name="BtnAdd"  Content="Добавить" Visibility="{Binding Control}" Click="BtnAdd_Click">
        </Button>

   
    </Grid>
</Page>
